# ── TrezzWorld Production Studio — environment variables ──────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.

# ── AI / LUMI ─────────────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=

# Optional direct provider fallbacks used automatically when OpenRouter is empty,
# rate-limited, or out of credit.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional local model support ──────────────────────────────────────────────
# Leave blank unless you are running Ollama on the same host or a remote Ollama
# service. If your Ollama instance is secured, also set OLLAMA_API_KEY.
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=
