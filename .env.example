# ── TrezzWorld Production Studio — environment variables ──────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.
# If you keep a shared master file for multiple repos, point MASTER_FILE at it.

# ── Shared / master file support ───────────────────────────────────────────────
MASTER_FILE=
MASTER_ENV_FILE=
SHARED_ENV_FILE=
ENV_FILE=
DOTENV_PATH=
# Optional: path(s) to additional repos or directories that should be scanned for a shared master document.
# When those repos exist as sibling folders next to this project, you can list the folder names directly:
# MASTER_DOCUMENT_REPOS=studio.trezzhaus.com,trezzworld-studio-production
# When they are mounted in deployment, use absolute paths instead:
# MASTER_DOCUMENT_REPOS=/repos/studio.trezzhaus.com,/repos/trezzworld-studio-production
MASTER_DOCUMENT=
MASTER_DOCUMENT_PATH=
MASTER_DOC_PATH=
MASTER_DOCUMENT_REPOS=

# ── Runtime / browser / security ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TREZZWORLD_PROTOCOL=trezzworld
CRASH_REPORT_URL=

# ── AI / LUMI ─────────────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=
# Enable production auth for /api/lumi/chat and /api/lumi/stream. Set to true
# once you have a shared API key or TrezzHaus SSO bearer auth in place.
AUTH_REQUIRED=true
LUMI_API_KEY=
# Per-client requests per minute for the live LUMI endpoints.
LUMI_RATE_LIMIT_PER_MINUTE=60
# Optional production URL used by deployment validation and health checks.
PRODUCTION_URL=https://app.trezzhaus.com
# Optional observability / uptime hooks for launch readiness.
SENTRY_DSN=
LOGTAIL_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
UPTIME_MONITOR_URL=
APP_ENV=production

# ── Optional local model support ──────────────────────────────────────────────# Leave blank unless you are running Ollama on the same host
OLLAMA_HOST=http://localhost:11434

# ── Photorealistic video frame generation ──────────────────────────────────────
# Get a free key at https://huggingface.co/settings/tokens (Stable Diffusion XL/3)
HUGGINGFACE_API_KEY=
# Get a key at https://fal.ai/dashboard/keys (Wan 2.2 / Kling video fallback)
FAL_KEY=

# Optional override if ffmpeg is not on PATH
FFMPEG_PATH=
# Optional overrides for where generated files are written. Point these at
# your mounted Railway Volume (e.g. /data/exports/video) if you want
# generated videos/music/Roblox ZIPs to survive redeploys instead of just
# living for the container's current lifetime. NOTE: your default Railway
# Volume is small (often 1GB) — videos add up fast; bump the Volume size if
# you do this, or rely on the automatic cleanup (EXPORT_RETENTION_HOURS).
VIDEO_EXPORT_DIR=
MUSIC_EXPORT_DIR=
MUSIC_ARCHIVE_DIR=
ROBLOX_EXPORT_DIR=
# How long generated files are kept before automatic cleanup deletes them
# (protects disk regardless of where exports are pointed). Default: 48 hours.
EXPORT_RETENTION_HOURS=48

# ── Roblox publishing (Lumi → Roblox Game Producer) ─────────────────────────────
# Static admin API key fallback — used only if no Roblox OAuth session is signed in.
# Open Cloud API key with "universe-places:write" scope: https://create.roblox.com/credentials
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# ── Roblox OAuth2 ("Sign in with Roblox") ───────────────────────────────────────
# Register an OAuth app at https://create.roblox.com/credentials. Set the app's
# redirect URI to exactly: https://studio.trezzhaus.com/api/roblox/oauth/callback
# NEVER paste the client secret anywhere other than here (Railway env vars).
ROBLOX_OAUTH_CLIENT_ID=
ROBLOX_OAUTH_CLIENT_SECRET=
ROBLOX_OAUTH_REDIRECT_URI=https://studio.trezzhaus.com/api/roblox/oauth/callback

# ── Persistent storage (API keys saved in Settings, mission history) ───────────
# On Railway: create a Volume (Service → Settings → Volumes), mount it at /data,
# then set DATA_DIR=/data here. Without this, anything saved via the Settings
# tab is lost on every redeploy — Railway's container filesystem is ephemeral.
DATA_DIR=
