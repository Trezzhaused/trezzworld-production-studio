# ── TrezzWorld Production Studio — environment variables ──────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.

# ── AI / LUMI (Text) ──────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Image Generation (Real Photographic AI) ───────────────────────────────────
# HuggingFace — FREE tier, supports FLUX.1-dev, SDXL, SD3
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=

# HuggingFace image model to use (default: black-forest-labs/FLUX.1-dev)
# Options: black-forest-labs/FLUX.1-dev | stabilityai/stable-diffusion-xl-base-1.0
#          stabilityai/stable-diffusion-3-medium-diffusers
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-dev

# HuggingFace music model to use (default: facebook/musicgen-stereo-small)
# Options: facebook/musicgen-stereo-small | facebook/musicgen-medium | facebook/musicgen-stereo-medium
HF_MUSIC_MODEL=facebook/musicgen-stereo-small

# Replicate — pay-per-use, supports FLUX, SDXL, Wan2.1 video, MusicGen
# Get token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# fal.ai — fast inference, supports FLUX, CogVideoX, Wan2.1 video
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=

# ── Video Generation (AI Cinematic Video) ─────────────────────────────────────
# RunwayML Gen-3 — cinematic video generation
# Get key: https://app.runwayml.com/settings
RUNWAY_API_KEY=

# ── Local Stable Diffusion (AUTOMATIC1111 or Forge WebUI) ─────────────────────
# Run AUTOMATIC1111 locally for free unlimited image generation
# Setup: https://github.com/AUTOMATIC1111/stable-diffusion-webui
# Start: python launch.py --api --port 7860
STABLE_DIFFUSION_HOST=http://localhost:7860

# ── ImagineArt — image, video, audio, edit, upscale tools ─────────────────────
# Get key: https://www.imagine.art (account settings → API)
# Supports: GPT Image 2, ImagineArt 2.0, Recraft V4.1 Pro, FLUX.2 Pro, Kling o3,
#           Runway 4.5, Google Veo 3.1, Seedance 2.0, Wan 2.6 and more.
IMAGINEART_API_KEY=

# ── Optional local model support ──────────────────────────────────────────────
# Leave blank unless you are running Ollama on the same host
OLLAMA_HOST=http://localhost:11434
