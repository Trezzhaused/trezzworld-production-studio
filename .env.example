# ── TrezzWorld Production Studio — environment variables ──────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file — it is in .gitignore.

# ── AI / LUMI ─────────────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Optional local model support ──────────────────────────────────────────────
# Leave blank unless you are running Ollama on the same host
OLLAMA_HOST=http://localhost:11434

# ── Photorealistic video frame generation ──────────────────────────────────────
# Get a free key at https://huggingface.co/settings/tokens (Stable Diffusion XL/3)
HUGGINGFACE_API_KEY=
# Get a key at https://fal.ai/dashboard/keys (Wan 2.2 / Kling video fallback)
FAL_KEY=

# Optional override if ffmpeg is not on PATH
FFMPEG_PATH=
# Optional override for where video exports are written
VIDEO_EXPORT_DIR=

# ── Roblox publishing (Lumi → Roblox Game Producer) ─────────────────────────────
# Open Cloud API key with "universe-places:write" scope: https://create.roblox.com/credentials
ROBLOX_API_KEY=
ROBLOX_UNIVERSE_ID=
ROBLOX_PLACE_ID=

# ── Persistent storage (API keys saved in Settings, mission history) ───────────
# On Railway: create a Volume (Service → Settings → Volumes), mount it at /data,
# then set DATA_DIR=/data here. Without this, anything saved via the Settings
# tab is lost on every redeploy — Railway's container filesystem is ephemeral.
DATA_DIR=
